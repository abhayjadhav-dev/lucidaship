# ══════════════════════════════════════════════════════════════
# Lucida Backend — Environment Variables
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env to source control.
# ══════════════════════════════════════════════════════════════

# ── Turso Database ───────────────────────────────────────────
# Leave blank for local SQLite development.
# Set both TURSO_DATABASE_URL and TURSO_AUTH_TOKEN to use Turso.
# Get from: turso db show lucida --url
TURSO_DATABASE_URL=

# Get from: turso db tokens create lucida
TURSO_AUTH_TOKEN=

# Require Turso in production (recommended true for hosted deployments)
REQUIRE_TURSO_IN_PRODUCTION=true

# Local SQLite fallback path for development
SQLITE_DB_PATH=./.local/lucida_local.db

# ── Clerk Authentication ────────────────────────────────────
# Leave blank for local development auth bypass.
# Set in production, or when testing Clerk-backed auth locally.
# Get from: dashboard.clerk.com → your app → API Keys
# Secret key (backend only, starts with sk_test_ or sk_live_)
CLERK_SECRET_KEY=
# Publishable key (starts with pk_test_ or pk_live_)
CLERK_PUBLISHABLE_KEY=
# JWT issuer URL for strict claim verification (e.g. https://your-instance.clerk.accounts.dev)
CLERK_JWT_ISSUER=
# Optional audience(s), comma-separated. Leave blank unless your Clerk JWT uses aud claim.
CLERK_JWT_AUDIENCE=
# Optional allowed authorized-party origins (azp), comma-separated.
CLERK_ALLOWED_AZP_ORIGINS=
# Clock skew tolerance in seconds for token time claims
CLERK_JWT_LEEWAY_SECONDS=10

# Local auth bypass toggle (development only).
# Set to false in any hosted environment so every request requires Clerk auth.
AUTH_BYPASS_ENABLED=false

# ── Application ─────────────────────────────────────────────
# Set to "production" for Railway deployment
# In production, CLERK_SECRET_KEY and at least one explicit CORS origin are required.
ENVIRONMENT=development

# Comma-separated allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://lucidaanalytics.tech

# Directory where trained .joblib model files are stored
MODEL_ARTIFACTS_DIR=./model_artifacts

# Free-plan quota: how many distinct model names each account can create.
# Retraining the same model name remains allowed.
FREE_PLAN_MAX_MODELS=1

# Maximum accepted CSV upload size in megabytes
MAX_CSV_SIZE_MB=200

# Maximum total multipart payload size per request (all files combined)
MAX_TOTAL_UPLOAD_SIZE_MB=300

# Maximum number of CSV files accepted per request
MAX_UPLOAD_FILES=8

# Maximum columns and rows accepted per CSV file
MAX_COLUMNS_PER_FILE=500
MAX_ROWS_PER_FILE=2000000

# Maximum queued+processing async training jobs per tenant
MAX_CONCURRENT_JOBS_PER_TENANT=2

# Per-tenant route limits (requests per minute)
RATE_LIMIT_TRAIN_PER_MIN=8
RATE_LIMIT_SCORE_PER_MIN=30
RATE_LIMIT_FEEDBACK_PER_MIN=12

# Score response and persistence controls for large datasets
# full = store all lead payloads, minimal = store top payloads and signature-only for rest, off = disable score persistence
SCORE_PERSISTENCE_MODE=minimal
MAX_PERSISTED_SCORED_ROWS_PER_RUN=50000
SCORE_PERSISTENCE_TOP_N_FULL_PAYLOAD=2000
MAX_SCORE_RESPONSE_ROWS=10000

# Data retention windows (automatic periodic cleanup)
SCORED_LEADS_RETENTION_DAYS=14
FEEDBACK_RETENTION_DAYS=180

# Chunk size for feedback signature lookups against scored rows
FEEDBACK_LOOKUP_BATCH_SIZE=500

# Upload-time numeric compression
UPLOAD_COMPRESSION_ENABLED=true
UPLOAD_COMPRESSION_MODE=shadow
UPLOAD_COMPRESSION_NUMERIC_ONLY=true
UPLOAD_COMPRESSION_MIN_ROWS=128
UPLOAD_COMPRESSION_MAX_ALLOWED_MSE=0.05
UPLOAD_COMPRESSION_MAX_ALLOWED_IP_ERROR=0.10
